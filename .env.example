# AI CLI Environment Variables Example

# This file serves as a template for the environment variables required to run the AI CLI application.
# Users should create a .env file in the same directory and populate it with their own API keys.

# OpenAI API Key
OPENAI_API_KEY="your_openai_api_key_here"

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Perplexity AI API Key
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# xAI Grok API Key
XAI_API_KEY=your_xai_api_key_here

# Mistral AI API Key
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Together AI API Key
TOGETHER_API_KEY=your_together_api_key_here

# Cohere API Key
COHERE_API_KEY=your_cohere_api_key_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fireworks AI API Key
FIREWORKS_API_KEY=your_fireworks_api_key_here

# GitHub Models Token
GITHUB_TOKEN=your_github_token_here